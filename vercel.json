{
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/scan-live",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/scan-ev",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/scan-middles",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "app/api/cron/scan/route.js": {
      "maxDuration": 30
    },
    "app/api/cron/scan-live/route.js": {
      "maxDuration": 30
    },
    "app/api/cron/scan-ev/route.js": {
      "maxDuration": 30
    },
    "app/api/cron/scan-middles/route.js": {
      "maxDuration": 30
    }
  }
}
